{
	"index": "/index.html",
	"assetGroups": [
		{
			"name": "app",
			"installMode": "prefetch",
			"resources": {
				"files": [
					"/favicon.ico",
					"/index.html",
					"/*.css",
					"/*.js"
				]
			}
		},
		{
			"name": "assets",
			"installMode": "lazy",
			"updateMode": "prefetch",
			"resources": {
				"files": [
					"/assets/**",
					"/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
				]
			}
		}
	],
	"dataGroups": [
		{
			"name": "firebase-images",
			"urls": [
				"https://firebasestorage.googleapis.com/v0/b/book-f941b.appspot.com/o/images/**"
			],
			"cacheConfig": {
				"strategy": "performance",
				"maxSize": 100,
				"maxAge": "365d",
				"timeout": "0u"
			}
		}
	]
}
